# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Database (PostgreSQL, see STACK.md) ---
# Connection string for the managed Postgres instance.
DATABASE_URL="postgresql://user:password@localhost:5432/ai_receptionist?schema=public"

# --- Auth.js / NextAuth (session signing) ---
# Generate one with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=""

# --- AI phone system API access (per-clinic keys are issued later) ---
# Placeholder for the shared/base key the external AI caller uses.
# Real per-clinic keys are part of the Foundation slice, not configured yet.
AI_PHONE_API_KEY=""
